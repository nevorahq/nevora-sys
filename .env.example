# Supabase (public client credentials)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@example.com

# Supabase service-role key — SERVER-ONLY, никогда не отдаётся клиенту.
# Используется для серверного rate-лимитера (вызов check_rate_limit, доступного
# только service_role) и durable extraction sweep-воркера (cross-org доступ).
# Если не задан — rate limiting и sweep деградируют в no-op (fail-open).
SUPABASE_SERVICE_ROLE_KEY=

# Resend transactional email. Use a verified sender/domain in Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Nevora <bookings@example.com>"

# Anthropic — powers the AI module (summaries, insights, recommendations)
# and Document-to-Transaction extraction (OCR/vision normalization).
ANTHROPIC_API_KEY=

# Billing mode.
# private_beta disables self-serve paid checkout and Customer Portal.
# stripe requires server-side Stripe secrets, webhook secret, and paid Price IDs.
BILLING_MODE=private_beta
BILLING_PROVIDER=

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Stripe Price IDs
STRIPE_PRICE_FREE_MONTHLY=
STRIPE_PRICE_STARTER_MONTHLY=price_your_starter_monthly_price_id
STRIPE_PRICE_STARTER_YEARLY=price_your_starter_yearly_price_id
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_price_id
STRIPE_PRICE_PRO_YEARLY=price_your_pro_yearly_price_id
STRIPE_PRICE_BUSINESS_MONTHLY=price_your_business_monthly_price_id
STRIPE_PRICE_BUSINESS_YEARLY=price_your_business_yearly_price_id

# Document-to-Transaction: when "1"/"true", stubs AI extraction (no Anthropic
# credits) for local testing. Leave unset/"0" for real extraction.
DOCUMENT_EXTRACTION_MOCK=0

# Cron auth — REQUIRED for /api/cron/extraction-sweep (fail-closed). Generate
# with `openssl rand -hex 32` and set the same value in Vercel project env.
# Vercel Cron sends it automatically as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# Internal metrics auth — REQUIRED for /api/internal/activation-funnel
# (fail-closed: unset means the endpoint refuses to answer). Cross-org activation
# funnel for the product team; returns aggregates only. Generate with
# `openssl rand -hex 32`. Keep it distinct from CRON_SECRET so leaking one does
# not hand over the other.
METRICS_SECRET=

# Set to "1" to enable the opt-in DB-backed integration test
# (extraction-pipeline.integration.test.ts). Requires the Supabase env above and
# a LOCAL/test database — never run against production.
RUN_DB_TESTS=
