# Supabase (public client credentials)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER-ONLY, никогда не отдаётся клиенту.
# Используется для серверного rate-лимитера (вызов check_rate_limit, доступного
# только service_role) и durable extraction sweep-воркера (cross-org доступ).
# Если не задан — rate limiting и sweep деградируют в no-op (fail-open).
SUPABASE_SERVICE_ROLE_KEY=

# Resend transactional email. Use a verified sender/domain in Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Nevora <bookings@example.com>"

# Anthropic — powers the AI module (summaries, insights, recommendations)
# and Document-to-Transaction extraction (OCR/vision normalization).
ANTHROPIC_API_KEY=

# Document-to-Transaction: when "1"/"true", stubs AI extraction (no Anthropic
# credits) for local testing. Leave unset/"0" for real extraction.
DOCUMENT_EXTRACTION_MOCK=0

# Cron auth — REQUIRED for /api/cron/extraction-sweep (fail-closed). Generate
# with `openssl rand -hex 32` and set the same value in Vercel project env.
# Vercel Cron sends it automatically as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# Set to "1" to enable the opt-in DB-backed integration test
# (extraction-pipeline.integration.test.ts). Requires the Supabase env above and
# a LOCAL/test database — never run against production.
RUN_DB_TESTS=
